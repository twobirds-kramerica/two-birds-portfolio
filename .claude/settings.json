{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python hal-stack/notion-sync/post-commit-hook.py",
            "if": "Bash(git commit*)",
            "timeout": 15,
            "async": true,
            "statusMessage": "Logging commit to Notion SESSION-STATE (Live)"
          }
        ]
      }
    ]
  }
}
